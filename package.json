{
  "name": "beleqet-jobs",
  "version": "1.0.0",
  "private": true,
  "description": "Beleqet Jobs — monorepo (Next.js frontend + NestJS API)",
  "scripts": {
    "dev:web": "npm run dev --prefix frontend",
    "dev:api": "npm run start:dev --prefix backend",
    "build:web": "npm run build --prefix frontend",
    "build:api": "npm run build --prefix backend",
    "lint:web": "npm run lint --prefix frontend",
    "setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-local.ps1",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend",
    "db:push": "npm run prisma:generate --prefix backend && npx prisma db push --schema backend/prisma/schema.prisma",
    "db:seed": "npm run prisma:seed --prefix backend"
  },
  "engines": {
    "node": ">=20"
  }
}
